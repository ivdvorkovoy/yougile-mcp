YOUGILE_BASE_URL=https://your-domain.com
YOUGILE_MCP_TRANSPORT=streamable-http
YOUGILE_MCP_HOST=0.0.0.0
YOUGILE_MCP_PORT=3333

# Option 1: already have an API key
YOUGILE_API_KEY=

# Option 2: let the app derive / fetch an API key
YOUGILE_EMAIL=
YOUGILE_PASSWORD=
YOUGILE_COMPANY_ID=
YOUGILE_COMPANY_NAME=

# Optional overrides for auth endpoints if your YouGile deployment differs
YOUGILE_COMPANY_ID_PATH=/api-v2/auth/companies
YOUGILE_API_KEY_PATH=/api-v2/auth/keys
YOUGILE_API_KEY_LIST_PATH=/api-v2/auth/keys/get
YOUGILE_API_KEY_DELETE_PATH=/api-v2/auth/keys
YOUGILE_DOTENV_PATH=.env

# Optional behavior tweaks
YOUGILE_TIMEOUT_SECONDS=30
YOUGILE_RATE_LIMIT_PER_MINUTE=50
